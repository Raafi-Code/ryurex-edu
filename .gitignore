# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =========================
# Dependencies
# =========================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================
# Build / Output
# =========================
/.next/
/out/
/build

# =========================
# Environment & Secrets
# =========================
.env
.env.*
.env.local
.env.*.local
!.env.example

# =========================
# Testing
# =========================
/coverage

# =========================
# Vercel
# =========================
.vercel

# =========================
# TypeScript
# =========================
*.tsbuildinfo
next-env.d.ts

# =========================
# Supabase
# =========================
/.supabase*
supabase/.temp/
supabase/.branches/

# Database files (backups, exports, seeds)
*.bak
*.backup
*.dump
supabase/seed.sql
supabase/schema.sql

# =========================
# IDE / Editor
# =========================
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# =========================
# OS Generated Files
# =========================
.DS_Store
Thumbs.db
Desktop.ini

# =========================
# Debug & Build Logs
# =========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
build-log.txt

# =========================
# Keys & Certificates
# =========================
*.pem
*.key
*.crt
keys/

# =========================
# AI / Docs (generated)
# =========================
.ai-docs

# =========================
# Misc
# =========================
*.tmp
*.temp
local_db/
